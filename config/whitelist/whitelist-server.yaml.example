# whitelist-server.yaml — config for the centralized whitelist server (cmd/server).
# Mounted into the whitelist-server container as /root/deepfry/whitelist.yaml.
#
# SETUP: copy this file to whitelist-server.yaml (gitignored) and adjust for THIS host:
#     cp whitelist-server.yaml.example whitelist-server.yaml
#
# dgraph_graphql_url: where Dgraph's GraphQL endpoint lives.
#   - Same docker network (single-host deploy):  http://dgraph:8080/graphql
#   - Dgraph on a different LAN host:             http://<dgraph-ip>:8080/graphql
dgraph_graphql_url: "http://dgraph:8080/graphql"
refresh_interval: 6h
refresh_retry_count: 3
idle_conn_timeout: 90s
http_timeout: 30s
query_timeout: 20m
server_listen_addr: ":8081"
# Bloom filter false-positive rate served at GET /bloom (default 1e-6). Uncomment to override.
# bloom_fp_rate: 0.000001
# Verbose logging. Leave true for dev; set false (or omit) in production.
debug: true
