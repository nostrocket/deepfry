# lmdb2graphql.yaml — example config
#
# Runtime location: ~/deepfry/lmdb2graphql.yaml
# This example file lives in: spam/config/lmdb2graphql.yaml.example
#
# DeepFry convention: operator copies this file to ~/deepfry/lmdb2graphql.yaml
# and fills in the actual strfry DB path for their deployment.
#
# NEVER delete or overwrite ~/deepfry/lmdb2graphql.yaml in tests — use tempdir.

# Path to the directory containing strfry's data.mdb (the LMDB env dir).
strfry_db_path: /app/strfry-db

# HTTP bind address for the GraphQL server.
#
# DEFAULT (bare-metal / dev):
#   bind_address: "127.0.0.1:8080"   # loopback — only reachable locally (CR-01)
#
# REQUIRED when running inside Docker (OPS-02 / RESEARCH.md Pitfall 2):
#   bind_address: "0.0.0.0:8080"     # <-- USE THIS LINE INSIDE DOCKER
#
# Inside a Docker container, 127.0.0.1 binds to the container's loopback interface
# which is invisible to the host and to other containers on deepfry-net. The port
# published in docker-compose.lmdb2graphql.yml ("127.0.0.1:8080:8080") restricts
# host exposure to the loopback — so setting 0.0.0.0 inside the container does NOT
# expose the service publicly; the docker publish rule is the actual exposure control.
bind_address: "0.0.0.0:8080"

# LMDB map_size in bytes — must match or exceed strfry's configured dbParams.mapsize.
# Default matches ../config/strfry/strfry.conf: mapsize = 10995116277760 (10 TiB).
map_size: 10995116277760

# Pinned strfry Docker image reference — includes full immutable sha256 digest (D-08/D-09).
# Pin: dockurr/strfry:1.1.0
# Full digest: dockurr/strfry@sha256:545555da5dd2c2b502f2c0d159f4dc4996d0e488e3bf25905ce881722d63d2c5
pinned_strfry_version: "dockurr/strfry@sha256:545555da5dd2c2b502f2c0d159f4dc4996d0e488e3bf25905ce881722d63d2c5"

