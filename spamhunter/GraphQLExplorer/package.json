{
  "name": "graphql-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "test": "vitest run",
    "postinstall": "node scripts/check-graphql-pin.cjs"
  },
  "dependencies": {
    "@urql/core": "^6",
    "graphql": "16.14.2",
    "nostr-tools": "2.23.8",
    "react": "^19",
    "react-dom": "^19",
    "urql": "^5"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7",
    "@graphql-codegen/client-preset": "^6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "typescript": "~5.9",
    "vite": "^7",
    "vitest": "^3.2.6"
  }
}
